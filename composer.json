{
    "name": "tweakwise/magento2-tweakwise-js",
    "license": "OSL-3.0",
    "description": "Magento 2 module for Tweakwise JS",
    "type": "magento2-module",
    "require": {
        "php": "^8.1",
        "tweakwise/magento2-tweakwise-export": "^7.0",
        "emico/m2-attributelanding": "^6.0.5",
        "magento/module-search": "^101.1",
        "ext-simplexml": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "emico/code-quality": "^10.0",
        "symfony/config": "^6.0"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "Tweakwise\\TweakwiseJs\\": "src/"
        }
    },
    "repositories": {
        "emico": {
            "type": "composer",
            "url": "https://git.emico.io/api/v4/group/239/-/packages/composer/"
        },
        "magento": {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    },
    "config": {
        "allow-plugins": {
            "magento/composer-dependency-version-audit-plugin": false,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "phpro/grumphp": true,
            "emico/code-quality": true
        },pl
        "preferred-install": {
            "emico/code-quality": "dist"
        }
    }
}
